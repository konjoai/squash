# Phase G.5 — Bandit security linter config
# Run via: bandit -r squash/ -ll
# Severity: MEDIUM and HIGH only (LOW is mostly noise on legitimate
# subprocess / hash usage in this codebase).

[bandit]
exclude_dirs = ["tests", "experimental", "research"]

# B404 (subprocess import) and B603 (subprocess without shell=True checks)
# are allowed — squash legitimately wraps git/cosign/openssl. Reviewers
# inspect subprocess call sites manually.
skips = ["B404", "B603", "B311"]

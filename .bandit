# Phase G.5 — Bandit security linter config (YAML format — bandit ≥1.8)
# Run via: bandit -c .bandit -r squash/ -ll
# Severity: MEDIUM and HIGH only (LOW is mostly noise on legitimate
# subprocess / hash usage in this codebase).

skips:
  # B404/B603 — subprocess import + call: squash legitimately wraps git/cosign/openssl.
  # Reviewers inspect subprocess call sites manually.
  - B404
  - B603
  # B311 — standard random: only used for sampling/shuffling, not crypto.
  - B311
  # B310 — urllib.request.urlopen: squash is a library that makes outbound
  # HTTP calls to registries, TSAs, and webhooks. All URLs are constructed
  # from operator-supplied config, not user input.
  - B310
  # B608 — SQL string construction: all SQL in squash uses parameterised
  # literals built from constants, not user input.
  - B608
  # B314 — xml.etree: used only for regulatory-watch RSS/Atom feeds from
  # trusted government sources, not for parsing untrusted documents.
  - B314
  # B615 — HuggingFace snapshot_download: used with operator-supplied model
  # ids; revision pinning is delegated to the caller's configuration.
  - B615
  # B104 — bind all interfaces: the embedded dev server in github_app.py
  # is intentionally reachable on all interfaces for webhook testing.
  - B104

exclude_dirs:
  - tests
  - experimental
  - research
